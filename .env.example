# ===========================================
# FILMERSHUB - VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ===========================================
# DJANGO
# ===========================================
# Chave secreta (gere uma chave forte para produção)
# Python: from django.core.management.utils import get_random_secret_key
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Modo debug (True em desenvolvimento, False em produção)
DJANGO_DEBUG=True

# Settings do Django
DJANGO_SETTINGS_MODULE=config.settings.development

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# BANCO DE DADOS (Docker)
# ===========================================
DATABASE_URL=postgres://filmershub:filmershub@localhost:5432/filmershub

# ===========================================
# REDIS (Docker)
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# URL do frontend para permitir requisições
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===========================================
# JWT (JSON Web Token)
# ===========================================
# Tempo de vida do access token (minutos)
JWT_ACCESS_TOKEN_LIFETIME=30

# Tempo de vida do refresh token (minutos) - 7 dias
JWT_REFRESH_TOKEN_LIFETIME=10080

# ===========================================
# MERCADO PAGO (configurar depois)
# ===========================================
# Tokens de acesso do Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_WEBHOOK_SECRET=

# Comissão da plataforma (%)
# PLATFORM_COMMISSION_PERCENTAGE=15.00

# ===========================================
# SENDGRID (configurar depois)
# ===========================================
# API Key do SendGrid para envio de emails
# SENDGRID_API_KEY=
# SENDGRID_DEFAULT_FROM=noreply@filmershub.com

# ===========================================
# EMAIL (desenvolvimento)
# ===========================================
# Backend de email (console mostra no terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
